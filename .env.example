# Environment Variables — Local Development Only
# Copy this file to .env and fill in the values
# In PRODUCTION (Docker), each variable is a file in ./secrets/

DATABASE_URL="postgresql://postgres:your_password@localhost:5432/maris_shop?schema=public"
JWT_SECRET="your-very-strong-random-secret-key"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
ADMIN_EMAIL="admin@your-domain.com"
